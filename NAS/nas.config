# =============================================================================
# nas.config — configuration for nas.sh
# =============================================================================

# === Connection ===
HPC_USER=lkyamamo
HPC_HOST=endeavour.usc.edu
REMOTE_BASE=/project/priyav_216/Tians
LOCAL_BASE=/Volumes/NAS/Tians

# === Transfer mode default ===
# archive : compress on HPC via SLURM then rsync down
# direct  : recursive rsync with no compression
DEFAULT_MODE=archive

# === Compression ===
COMPRESSION_LEVEL=3        # 1 (fastest) → 19 (smallest)
COMPRESSION_THREADS=16     # sets both zstd -T and SLURM --cpus-per-task

# === Thresholds ===
# Dirs larger than MAX_ARCHIVE_SIZE are not bundled — files compressed individually
MAX_ARCHIVE_SIZE=100G
# Files smaller than MIN_FILE_SIZE are bundled into a single tar.zst instead of individual .zst
MIN_FILE_SIZE=10M

# === SLURM ===
SLURM_PARTITION=priya
SLURM_TIME=4:00:00
MAX_CONCURRENT_JOBS=5      # max simultaneous SLURM compression jobs per directory

# === Directories ===
# Format: "dirname" or "dirname:mode" where mode overrides DEFAULT_MODE
DIRECTORIES=(
    "1020-rxmd-algo"
    "allegro-ymno3"
    "CIPS_runs"
    "codeForGr"
    "md-ymno3"
    "rxmd_rl"
)
